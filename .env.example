LKB_ENV=development
# SQLite fallback:
# LKB_DATABASE_URL=sqlite:///E:/project/living-kb/storage/living_kb.db
# Postgres + pgvector:
LKB_DATABASE_URL=postgresql+psycopg2://app_user:app_password@127.0.0.1:5432/living_kb
LKB_DATA_ROOT=E:/project/living-kb/storage
LKB_STALE_DAYS=30
LKB_LLM_PROVIDER=none
LKB_OPENAI_MODEL=gpt-5-mini
LKB_MINIMAX_MODEL=MiniMax-M2.7
LKB_MINIMAX_BASE_URL=https://api.minimax.io/v1
LKB_EMBEDDING_PROVIDER=auto
LKB_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LKB_EMBEDDING_DIMENSIONS=1536
LKB_SCHEDULER_ENABLED=true
LKB_SCHEDULER_POLL_SECONDS=5
LKB_HEALTH_CHECK_INTERVAL_SECONDS=300
OPENAI_API_KEY=
MINIMAX_API_KEY=
